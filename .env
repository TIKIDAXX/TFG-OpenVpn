# ── Active Directory / LDAP ───────────────────────────────────
AD_HOST=localhost
AD_PORT=389
AD_BASE_DN=dc=domainsaid,dc=internal
AD_BIND_USER=cn=vpnbind,ou=serviceaccounts,dc=empresa,dc=local
AD_BIND_PASS=Cambiame123
AD_VPN_GROUP=cn=vpnusers,ou=groups,dc=domainsaid,dc=internal
AD_ADMIN_GROUP=cn=vpnadmins,ou=groups,dc=doaminsaid,dc=internal

# ── OpenVPN ───────────────────────────────────────────────────
OPENVPN_HOSTNAME=vpn.tfg.internal
OPENVPN_PORT=1194
OPENVPN_TCP_PORT=443
OPENVPN_NETWORK=10.8.0.0
OPENVPN_SUBNET=255.255.255.0
OPENVPN_DNS1=8.8.8.8
OPENVPN_DNS2=8.8.4.4
OPENVPN_MGMT_PORT=7505

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=052104
MYSQL_DATABASE=panelvpn
MYSQL_USER=paneluser
MYSQL_PASSWORD=052104
MYSQL_HOST=mysql
MYSQL_PORT=3306

# ── Portal Web ────────────────────────────────────────────────
PORTAL_SESSION_SECRET=tfgtfg
PORTAL_ADMIN_USER=admin
PORTAL_ADMIN_PASSWORD=admin1234
PORTAL_URL=https://localhost

# ── Nginx ─────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=8443

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=8640076502:AAGtYDOpa2YIYbaEJSMOVcZwEmIVuYUkiKA
TELEGRAM_CHAT_MAIN=6071128796
TELEGRAM_CHAT_MFA=-1003765040452
TELEGRAM_CHAT_SOPORTE=-1003249110299
TELEGRAM_ADMIN_IDS=0
TELEGRAM_SOPORTE_IDS=0
PORTAL_SESSION_SECRET=temporal123
# ── MFA / OTP ─────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=90
OTP_LENGTH=6

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin1234
GRAFANA_PORT=3000
GRAFANA_URL=http://grafana:3000
GRAFANA_ALLOW_EMBEDDING=true

# ── Prometheus ────────────────────────────────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d

# ── Loki ──────────────────────────────────────────────────────
LOKI_PORT=3100
LOKI_RETENTION=168h

# ── Fail2Ban ──────────────────────────────────────────────────
FAIL2BAN_MAXRETRY=5
FAIL2BAN_BANTIME=3600
FAIL2BAN_FINDTIME=600

# ── Alertas y umbrales ────────────────────────────────────────
ALERT_CPU_THRESHOLD=85
ALERT_RAM_THRESHOLD=85
ALERT_DISK_THRESHOLD=80
ALERT_CHECK_INTERVAL=60
